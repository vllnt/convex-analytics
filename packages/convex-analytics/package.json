{
  "name": "@vllnt/convex-analytics",
  "version": "0.1.0",
  "description": "Generic, configurable analytics component for Convex — any event, any dimension, any domain; rollup-on-write with funnels, retention, uniques",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "main": "./dist/client/index.js",
  "module": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./test": "./src/test.ts",
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp ../../README.md ../../LICENSE ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit",
    "lint": "eslint src/",
    "preversion": "pnpm install --frozen-lockfile && pnpm build && pnpm test:coverage && pnpm typecheck"
  },
  "dependencies": {
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/sharded-counter": "^0.2.0",
    "convex": "^1.21.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "convex-test": "^0.0.36",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "convex": ">=1.21.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "convex": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "bntvllnt",
    "url": "https://bntvllnt.com"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/bntvllnt"
  },
  "homepage": "https://github.com/vllnt/convex-analytics#readme",
  "bugs": {
    "url": "https://github.com/vllnt/convex-analytics/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vllnt/convex-analytics.git"
  },
  "keywords": [
    "convex",
    "convex-component",
    "analytics",
    "events",
    "metrics",
    "funnels",
    "retention",
    "rollup",
    "vllnt"
  ]
}
